.agent-screen {
  padding-bottom: 280rpx;
}

.agent-hero {
  background: linear-gradient(180deg, #ffffff 0%, #eef7f1 100%);
}

.agent-badge {
  width: 82rpx;
  height: 82rpx;
  border-radius: 24rpx;
  color: #fff;
  background: #1f7a4d;
  text-align: center;
  font-size: 34rpx;
  line-height: 82rpx;
  font-weight: 850;
}

.context-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
}

.context-card {
  width: calc(50% - 7rpx);
  padding: 18rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.74);
}

.context-value {
  margin-top: 8rpx;
  color: #101815;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 800;
}

.chat-title-row {
  margin-bottom: 22rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.agent {
  justify-content: flex-start;
}

.avatar {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #1f7a4d;
  text-align: center;
  font-size: 26rpx;
  line-height: 54rpx;
  font-weight: 850;
}

.bubble {
  max-width: 520rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  font-size: 25rpx;
  line-height: 1.55;
}

.bubble.user {
  color: #fff;
  background: #1f7a4d;
  border-bottom-right-radius: 6rpx;
}

.bubble.agent {
  color: #202722;
  background: #f3f5f0;
  border-bottom-left-radius: 6rpx;
}

.suggestion-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.suggestion {
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  color: #1f7a4d;
  background: #e5f0ea;
  font-size: 24rpx;
  font-weight: 750;
}

.next-card .body {
  margin-top: 14rpx;
}

.chat-composer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 128rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(24, 39, 30, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 32rpx rgba(19, 34, 25, 0.12);
  box-sizing: border-box;
}

.composer-plus {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  color: #1f7a4d;
  background: #e5f0ea;
  text-align: center;
  font-size: 36rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.composer-input {
  flex: 1;
  height: 60rpx;
  color: #101815;
  font-size: 25rpx;
}

.composer-send {
  padding: 0 24rpx;
  height: 58rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #1f7a4d;
  font-size: 24rpx;
  line-height: 58rpx;
  font-weight: 800;
}
