.model-head {
  min-height: auto;
}

.model-head .body {
  margin-top: 14rpx;
  max-width: 100%;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.model-chip {
  min-width: 154rpx;
  padding: 18rpx 24rpx;
  border: 3rpx solid #202420;
  box-sizing: border-box;
  text-align: center;
  color: #171b18;
  background: #fff;
  font-size: 32rpx;
  line-height: 1;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
}

.feature-list {
  margin-top: 26rpx;
}

.feature-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.feature-name {
  width: 92rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.feature-track {
  flex: 1;
  height: 20rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(24, 39, 30, 0.08);
}

.feature-fill {
  height: 100%;
  border-radius: 8rpx;
}

.greenbar {
  background: #1f7a4d;
}

.soilbar {
  background: #8b5e34;
}

.bluebar {
  background: #0e7490;
}

.midbar {
  background: #d99a21;
}

.warnbar {
  background: #c2410c;
}

.ink {
  background: #25323a;
}

.feature-score {
  width: 48rpx;
  color: #6f7570;
  text-align: right;
  font-size: 22rpx;
  font-weight: 700;
}

.note {
  margin-top: 14rpx;
}


.model-card-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.model-card {
  flex: 1;
  padding: 18rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(31, 122, 77, 0.08);
}

.model-card-value {
  margin: 8rpx 0 4rpx;
  color: #1f7a4d;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 850;
}

.year-list {
  margin-top: 22rpx;
}

.year-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.year-name {
  width: 76rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.year-track {
  flex: 1;
  height: 18rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(24, 39, 30, 0.08);
}

.year-fill {
  height: 100%;
  border-radius: 8rpx;
  background: #1f7a4d;
}

.year-r2 {
  width: 110rpx;
  color: #6f7570;
  text-align: right;
  font-size: 22rpx;
  font-weight: 700;
}
