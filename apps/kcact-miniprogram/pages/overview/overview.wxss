.hero {
  padding-bottom: 34rpx;
}

.hero-head {
  align-items: flex-start;
  gap: 22rpx;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.35;
}

.map-panel {
  position: relative;
  height: 458rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #203b3a;
}

.heat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 48rpx 42rpx;
  box-sizing: border-box;
}

.heat-cell {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  opacity: 0.86;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.08);
}

.heat-cell.low {
  background: #2f9e44;
}

.heat-cell.mid {
  background: #d99a21;
}

.heat-cell.high {
  background: #c2410c;
}

.spot {
  position: absolute;
  transform: translate(-50%, -50%);
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
}

.spot-sm {
  width: 72rpx;
  height: 72rpx;
}

.spot-md {
  width: 94rpx;
  height: 94rpx;
}

.spot-lg {
  width: 132rpx;
  height: 132rpx;
}

.spot-low {
  background: rgba(47, 158, 68, 0.84);
}

.spot-mid {
  background: rgba(217, 154, 33, 0.84);
}

.spot-high {
  background: rgba(194, 65, 12, 0.88);
}

.spot-label {
  position: absolute;
  left: 50%;
  bottom: -34rpx;
  transform: translateX(-50%);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(17, 24, 20, 0.48);
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.legend {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(12, 20, 18, 0.42);
  box-sizing: border-box;
}

.legend-item {
  margin-right: 20rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
}

.legend-title {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 700;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 8rpx;
  border-radius: 999rpx;
}

.low-dot {
  background: #2f9e44;
}

.mid-dot {
  background: #d99a21;
}

.high-dot {
  background: #c2410c;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric-card {
  width: 48%;
  min-height: 228rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(24, 39, 30, 0.08);
  border-radius: 16rpx;
  background: #fff;
  box-sizing: border-box;
}

.mark {
  margin-bottom: 30rpx;
  color: #1f7a4d;
  font-size: 24rpx;
  font-weight: 800;
}

.risk .body {
  margin-top: 12rpx;
}

.stage-list {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stage {
  flex: 1;
}

.stage-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(31, 122, 77, 0.12);
}

.stage-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #1f7a4d;
}

.stage-fill.active {
  background: #c2410c;
}

.stage-name {
  margin-top: 12rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
}
