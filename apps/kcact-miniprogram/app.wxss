page {
  min-height: 100%;
  color: #101815;
  background: #f4f6f1;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.screen {
  padding: 32rpx 28rpx 156rpx;
  box-sizing: border-box;
}

.section {
  width: 100%;
  margin-bottom: 28rpx;
  padding: 30rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 39, 30, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
}

.muted {
  color: #81868a;
}

.eyebrow {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: #1f7a4d;
  background: #e5f0ea;
  font-size: 24rpx;
  font-weight: 700;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.title-xl {
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: 0;
}

.title-lg {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
}

.title-md {
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 800;
}

.body {
  font-size: 26rpx;
  line-height: 1.55;
}

.caption {
  font-size: 22rpx;
  line-height: 1.4;
}

.value {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 850;
  letter-spacing: 0;
}

.metric-label {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
}

.metric-unit {
  margin-top: 4rpx;
  color: #8b8f93;
  font-size: 22rpx;
}

.progress-track {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(31, 122, 77, 0.11);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #1f7a4d;
}

.warn {
  color: #c2410c;
}

.green {
  color: #1f7a4d;
}

.soil {
  color: #8b5e34;
}
